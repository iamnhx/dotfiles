# Cryptocurrencies
brew 'cointop'                 # Interactive terminal based UI application for tracking cryptocurrencies

# E-Book and Reading
cask 'calibre'                 # E-books management software
brew 'pandoc'                  # Swiss-army knife of markup format conversion
cask 'thorium'                 # Epub reader

# File Management Tools
cask 'a-better-finder-rename'  # File renaming utility
cask 'daisydisk'               # Disk space visualizer
cask 'find-any-file'           # File search utility
cask 'macfuse'                 # FUSE file system support for macOS

# Network and Security
cask 'cloudflare-warp'         # Cloudflare WARP VPN
cask 'little-snitch'           # Firewall app for traffic monitoring
cask 'santa'                   # Binary authorization system
cask 'wireshark'               # Network protocol analyzer

# Productivity
brew 'busycal'                 # The Best Calendar App for macOS
cask 'espanso'                 # Live text expander (cross-platform)
cask 'maccy'                   # Clipboard manager (cross-platform)
cask 'notion'                  # Note-taking and collaboration
cask 'numi'                    # Calculator app
cask 'trex'                    # Easy-to-use text extraction tool

# System monitoring and utilities
cask 'kitty'                   # Kitty Terminal Emulator
