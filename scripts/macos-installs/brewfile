cask 'pictogram'               # Customize and maintain app icons
cask 'sloth'                   # Displays all open files and sockets in use by all running processes
cask 'soundsource'             # Sound and audio controller
cask 'tg-pro'                  # Temperature monitoring, fan control, and diagnostics

# Web browsers
cask 'brave-browser'           # Web browser focusing on privacy

